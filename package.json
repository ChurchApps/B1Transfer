{
  "name": "b1-transfer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@churchapps/apphelper": "^0.19.0",
    "@churchapps/helpers": "^1.9.2",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.3.11",
    "@stripe/react-stripe-js": "^3.9.1",
    "@stripe/stripe-js": "^7.8.0",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "buffer": "^6.0.3",
    "cropperjs": "^1.5.13",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "papaparse": "^5.5.3",
    "react": "^19.1.0",
    "react-activity": "^2.1.3",
    "react-cookie": "^8.0.1",
    "react-dom": "^19.1.0",
    "react-ga4": "^2.1.0",
    "react-router-dom": "^7.15.0",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "preinstall": "node -e \"if(!(process.env.npm_config_user_agent||'').startsWith('yarn')){console.error('\\n[B1Transfer] This project uses Yarn (Berry). Run \\'yarn install\\' instead of npm/pnpm.\\n');process.exit(1)}\"",
    "start": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "lint": "eslint --fix src/",
    "predeploy-staging": "VITE_STAGE=staging yarn build",
    "exec-deploy-staging": "aws s3 sync build/ s3://staging-chums-transfer",
    "postdeploy-staging": "aws cloudfront create-invalidation --distribution-id E28G9AODQAH4HQ --paths \"/*\"",
    "deploy-staging": "yarn predeploy-staging && yarn exec-deploy-staging && yarn postdeploy-staging",
    "predeploy-prod": "VITE_STAGE=prod yarn build",
    "exec-deploy-prod": "aws s3 sync build/ s3://chums-transfer",
    "postdeploy-prod": "aws cloudfront create-invalidation --distribution-id E29Q1TKCS5G75P --paths \"/*\"",
    "deploy-prod": "yarn predeploy-prod && yarn exec-deploy-prod && yarn postdeploy-prod",
    "postinstall": "copyfiles -a -f \"node_modules/@churchapps/apphelper/dist/public/locales/**\" public/apphelper/locales && copyfiles -a -f \"node_modules/@churchapps/apphelper/dist/public/css/**\" public/apphelper/css"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js}": [
      "eslint --fix"
    ]
  },
  "browserslist": [
    ">0.3%",
    "not ie 11",
    "not dead",
    "not op_mini all"
  ],
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.15.5",
    "@types/xlsx": "^0.0.36",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitejs/plugin-react": "^4.3.4",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "lint-staged": "^16.1.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  },
  "packageManager": "yarn@4.15.0",
  "dependenciesMeta": {
    "esbuild": {
      "built": true
    }
  }
}
